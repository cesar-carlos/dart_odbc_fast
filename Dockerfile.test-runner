# syntax=docker/dockerfile:1.6
#
# Linux test runner for `dart_odbc_fast`.
#
# Provides:
#   - Rust stable + cargo
#   - unixODBC + dev headers
#   - ODBC drivers for PostgreSQL, MySQL/MariaDB, IBM Db2 (ODBC CLI tarball)
#     and SQL Server 18
#   - Pre-baked /etc/odbcinst.ini that names the drivers exactly as the
#     project's connection-string templates expect (`PostgreSQL Unicode`,
#     `MySQL ODBC 8.0 Unicode Driver`, `MariaDB ODBC 3.1 Driver`,
#     `IBM DB2 ODBC DRIVER`, `ODBC Driver 18 for SQL Server`).
#
# Notes on what is NOT included:
#   - Oracle Instant Client + Oracle ODBC driver: opt-in at build
#     (INCLUDE_ORACLE) — see below.
#   - SQL Anywhere / Sybase ASA: same, proprietary.
#   - Snowflake: requires download from snowflake.com. Add a follow-up
#     COPY step on top of this image when needed.
#
# Build:  docker compose --profile test build test-runner
# Shell:  docker compose --profile test run --rm test-runner bash
# Tests:  docker compose --profile test run --rm test-runner \
#             cargo test --features ffi-tests -- --include-ignored

ARG RUST_VERSION=1.86
ARG INCLUDE_ORACLE=false

FROM rust:${RUST_VERSION}-bookworm

# -- Base toolchain + unixODBC ----------------------------------------------

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gnupg \
        wget \
        build-essential \
        pkg-config \
        unixodbc \
        unixodbc-dev \
        libssl-dev \
        netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

# -- PostgreSQL ODBC --------------------------------------------------------

RUN apt-get update && apt-get install -y --no-install-recommends \
        odbc-postgresql \
    && rm -rf /var/lib/apt/lists/*

# -- MariaDB / MySQL ODBC ---------------------------------------------------
#
# `odbc-mariadb` works against both MariaDB and MySQL servers; it registers
# itself as both `MariaDB ODBC 3.x Driver` and we add the `MySQL ODBC 8.0
# Unicode Driver` alias below in odbcinst.ini so the project's existing
# connection strings work out of the box.

RUN apt-get update && apt-get install -y --no-install-recommends \
        odbc-mariadb \
    && rm -rf /var/lib/apt/lists/*

# -- Microsoft SQL Server ODBC Driver 18 ------------------------------------

RUN curl -sSL https://packages.microsoft.com/keys/microsoft.asc \
        | gpg --dearmor -o /usr/share/keyrings/microsoft-prod.gpg \
    && echo "deb [arch=amd64,arm64 signed-by=/usr/share/keyrings/microsoft-prod.gpg] \
        https://packages.microsoft.com/debian/12/prod bookworm main" \
        > /etc/apt/sources.list.d/mssql-release.list \
    && apt-get update \
    && ACCEPT_EULA=Y apt-get install -y --no-install-recommends msodbcsql18 \
    && rm -rf /var/lib/apt/lists/*

# -- IBM Db2 ODBC / CLI driver ----------------------------------------------
#
# Public DHE build of the ODBC/CLI clidriver (same tarball `go_ibm_db` uses).
# Pinned version keeps CI reproducible; bump IBM_ODBC_CLI_VERSION when needed.
ARG IBM_ODBC_CLI_VERSION=v11.5.9
ENV IBM_DB_HOME=/opt/ibm/clidriver
RUN set -eux; \
    curl -fsSL "https://public.dhe.ibm.com/ibmdl/export/pub/software/data/db2/drivers/odbc_cli/${IBM_ODBC_CLI_VERSION}/linuxx64_odbc_cli.tar.gz" -o /tmp/linuxx64_odbc_cli.tar.gz; \
    mkdir -p /opt/ibm; \
    tar -xzf /tmp/linuxx64_odbc_cli.tar.gz -C /opt/ibm; \
    rm /tmp/linuxx64_odbc_cli.tar.gz; \
    test -d "${IBM_DB_HOME}/lib"; \
    if [ ! -e "${IBM_DB_HOME}/lib/libdb2o.so.1" ]; then \
        test -e "${IBM_DB_HOME}/lib/libdb2.so.1" || (ls -la "${IBM_DB_HOME}/lib"/libdb2*; exit 1); \
        ln -s "${IBM_DB_HOME}/lib/libdb2.so.1" "${IBM_DB_HOME}/lib/libdb2o.so.1"; \
    fi; \
    echo "/opt/ibm/clidriver/lib" > /etc/ld.so.conf.d/ibm-clidriver.conf; \
    ldconfig

# -- ODBC INI ---------------------------------------------------------------
#
# Override the upstream defaults so the driver names match the connection
# strings shipped in `.env.docker` and the example demos.

RUN cat > /etc/odbcinst.ini <<'EOF'
[PostgreSQL Unicode]
Description     = PostgreSQL ODBC driver (Unicode)
Driver          = /usr/lib/x86_64-linux-gnu/odbc/psqlodbcw.so
Setup           = /usr/lib/x86_64-linux-gnu/odbc/libodbcpsqlS.so
Threading       = 2
UsageCount      = 1

[MariaDB ODBC 3.1 Driver]
Description     = MariaDB ODBC 3.1 driver
Driver          = /usr/lib/x86_64-linux-gnu/libmaodbc.so
UsageCount      = 1

[MySQL ODBC 8.0 Unicode Driver]
Description     = MariaDB driver served as MySQL alias
Driver          = /usr/lib/x86_64-linux-gnu/libmaodbc.so
UsageCount      = 1

[ODBC Driver 18 for SQL Server]
Description     = Microsoft ODBC Driver 18 for SQL Server
Driver          = /opt/microsoft/msodbcsql18/lib64/libmsodbcsql-18.5.so.1.1
UsageCount      = 1

[IBM DB2 ODBC DRIVER]
Description     = IBM Data Server Driver for ODBC and CLI
Driver          = /opt/ibm/clidriver/lib/libdb2o.so.1
UsageCount      = 1
EOF

# -- Oracle Instant Client + ODBC (optional) --------------------------------
#
# Pulled at build time from the public Oracle CDN URLs that don't require a
# login (the same URLs the GitHub Actions Oracle job uses). Skipped by
# default to keep the base image small. To opt in:
#
#     docker compose --profile oracle-test build test-runner-oracle
#
# Once installed, the driver is registered as
# `[Oracle Instant Client ODBC]` and the runtime libs land under
# `/opt/oracle/instantclient_23_6` (added to ld.so.conf so cargo doesn't
# need LD_LIBRARY_PATH wrangling).
#
# Placed AFTER the `cat > /etc/odbcinst.ini` step above so its append
# doesn't get overwritten.

ARG INCLUDE_ORACLE
ENV INCLUDE_ORACLE=${INCLUDE_ORACLE}

RUN if [ "$INCLUDE_ORACLE" = "true" ] || [ "$INCLUDE_ORACLE" = "1" ]; then \
        set -eux; \
        apt-get update; \
        apt-get install -y --no-install-recommends unzip libaio1 || \
            apt-get install -y --no-install-recommends unzip libaio1t64; \
        curl -fsSL -o /tmp/ic-basiclite.zip \
            "https://download.oracle.com/otn_software/linux/instantclient/2360000/instantclient-basiclite-linux.x64-23.6.0.24.10.zip"; \
        curl -fsSL -o /tmp/ic-odbc.zip \
            "https://download.oracle.com/otn_software/linux/instantclient/2360000/instantclient-odbc-linux.x64-23.6.0.24.10.zip"; \
        mkdir -p /opt/oracle; \
        unzip -oq /tmp/ic-basiclite.zip -d /opt/oracle; \
        unzip -oq /tmp/ic-odbc.zip -d /opt/oracle; \
        rm /tmp/ic-basiclite.zip /tmp/ic-odbc.zip; \
        echo "/opt/oracle/instantclient_23_6" > /etc/ld.so.conf.d/oracle-instantclient.conf; \
        ldconfig; \
        { \
            echo ""; \
            echo "[Oracle Instant Client ODBC]"; \
            echo "Description = Oracle Instant Client ODBC"; \
            echo "Driver      = /opt/oracle/instantclient_23_6/libsqora.so.23.1"; \
            echo "Setup       = /opt/oracle/instantclient_23_6/libsqorasb23.so"; \
            echo "FileUsage   = 1"; \
            echo "UsageCount  = 1"; \
        } >> /etc/odbcinst.ini; \
        rm -rf /var/lib/apt/lists/*; \
    fi

# -- Dart SDK (optional; pulled lazily for `dart` invocations) --------------
#
# Many CI / dev workflows only need the Rust side here (since the FFI is
# the surface that talks to ODBC drivers). Dart is intentionally NOT
# baked in by default to keep the image small. Uncomment to add it:
#
# RUN apt-get update && apt-get install -y apt-transport-https \
#     && curl -sSL https://dl.google.com/linux/linux_signing_key.pub \
#         | gpg --dearmor -o /usr/share/keyrings/dart.gpg \
#     && echo "deb [signed-by=/usr/share/keyrings/dart.gpg arch=amd64] \
#         https://storage.googleapis.com/download.dartlang.org/linux/debian stable main" \
#         > /etc/apt/sources.list.d/dart_stable.list \
#     && apt-get update && apt-get install -y dart \
#     && rm -rf /var/lib/apt/lists/*

# Default workdir is mounted by docker-compose; nothing to copy here.
WORKDIR /workspace
